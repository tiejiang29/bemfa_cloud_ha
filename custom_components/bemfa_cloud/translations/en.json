{
  "config": {
    "step": {
      "user": {
        "title": "Bemfa Cloud",
        "menu_options": {
          "keys": "Enter keys manually",
          "pick_implementation": "Sign in with Bemfa OAuth"
        }
      },
      "keys": {
        "title": "Bemfa Cloud credentials",
        "data": {
          "uid": "Bemfa private key"
        }
      }
    },
    "error": {
      "invalid_uid": "Invalid Bemfa private key"
    },
    "abort": {
      "already_configured": "This Bemfa account is already configured",
      "oauth_failed": "OAuth authentication failed",
      "oauth_missing_uid": "OAuth succeeded, but the token response did not include a Bemfa private key."
    }
  },
  "options": {
    "error": {
      "cannot_sync": "Failed to sync to Bemfa Cloud. Check that the private key is correct, the network is reachable, and see the Home Assistant logs for details."
