    "step": {
      "init": {
        "title": "Bemfa Cloud",
        "menu_options": {
          "create_all_syncs": "Add syncs in bulk",
          "create_sync": "Add one sync",
          "modify_sync": "Edit sync settings",
          "destroy_sync": "Remove local sync"
        }
      },
      "create_all_syncs": {
        "title": "Add syncs in bulk",
        "description": "Create Bemfa TCP V2 topics for the selected entities and start syncing their states.",
        "data": {
          "select": "Entities"
        }
      },
      "create_sync": {
        "title": "Add one sync",
        "data": {
          "select": "Entity"
        }
      },
